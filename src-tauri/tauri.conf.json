{
  "productName": "Claude Agent Manager",
  "version": "0.1.0",
  "identifier": "com.cam.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Agent Manager",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false
      }
    },
    "publisher": "CAM",
    "shortDescription": "GUI manager for Claude Code agents, skills, and commands"
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
